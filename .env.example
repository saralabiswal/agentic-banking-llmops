# LLM (default: mock, no API key required)
LLM_BACKEND=mock
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Infrastructure (defaults match docker-compose.yml)
VALKEY_URL=redis://localhost:6379
POSTGRES_URL=postgresql+asyncpg://platform:platform@localhost:5432/platform
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base
MLFLOW_TRACKING_URI=http://localhost:5001
JAEGER_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=8001

# Platform
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Rules and knowledge base
RULES_DIR=rules
KB_DIR=knowledge_base
RULES_RELOAD_INTERVAL_SEC=5

# Layer 1
CONTEXT_TTL_SECONDS=300
SOURCE_ADAPTER_TIMEOUT_MS=150

# Layer 2
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_TOP_K=3
HYBRID_ALPHA=0.7

# Layer 3
AGENT_DEFAULT_TIMEOUT_MS=8000
PIPELINE_STATE_TTL_SECONDS=300

# Layer 5
EXPERIMENT_MIN_SAMPLE_SIZE=5000
EXPERIMENT_CONFIDENCE_THRESHOLD=0.95
PSI_WARNING_THRESHOLD=0.10
PSI_ALERT_THRESHOLD=0.25
RECALL_ALERT_THRESHOLD=0.78
